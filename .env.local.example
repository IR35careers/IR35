# IR35Careers Environment Variables
# Copy this file to .env.local and fill in the values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Server-side secrets (NEVER prefix these with NEXT_PUBLIC_) ──────────
# Supabase secret key (sb_secret_...) from Supabase → Settings → API Keys.
# Used only by server code: the job-fetch pipeline writes to the jobs table
# with this key. It must also be added to Vercel → Settings → Environment
# Variables for production.
SUPABASE_SECRET_KEY=your_supabase_secret_key

# Shared secret protecting the pipeline trigger endpoint. Make up a long
# random string (30+ characters). Vercel Cron automatically sends it as a
# Bearer token; you can also trigger manually in a browser:
#   https://ir35careers.com/api/pipeline/fetch?secret=YOUR_VALUE
CRON_SECRET=make_up_a_long_random_string

# ── Job-board aggregator APIs (the main source of contract jobs) ────────
# Reed.co.uk — free API key, instant signup:
#   https://www.reed.co.uk/developers/jobseeker
REED_API_KEY=your_reed_api_key

# Adzuna — free app credentials, instant signup:
#   https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Optional: Site URL for production
NEXT_PUBLIC_SITE_URL=https://ir35careers.com

# Countdown timer target
# Set this to your real launch date (ISO 8601) before going live — the homepage
# countdown counts down to this exact moment. If unset, it falls back to
# "NEXT_PUBLIC_COUNTDOWN_DAYS days from whenever the app was last built/started",
# which is only a placeholder and will drift on every redeploy.
# 30-day launch target from 16 July 2026 = 15 August 2026.
NEXT_PUBLIC_LAUNCH_DATE=2026-08-15T09:00:00Z

# Optional fallback only used if NEXT_PUBLIC_LAUNCH_DATE is not set. Defaults to 40.
NEXT_PUBLIC_COUNTDOWN_DAYS=30
